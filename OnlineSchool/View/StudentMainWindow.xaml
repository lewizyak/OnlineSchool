<Window x:Class="OnlineSchool.View.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineSchool.View"
        mc:Ignorable="d"
        Title="StudentMainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock x:Name="tbHello" FontSize="18" Margin="0,0,0,16"/>

        <Button Content="Мои курсы"
                Height="35"
                Margin="0,0,0,10"
                Click="BtnMyCourses_Click"/>

        <Button Content="Доступные курсы"
                Height="35"
                Margin="0,0,0,10"
                Click="BtnAvailableCourses_Click"/>

        <Button Content="Оценки"
                Height="35"
                Margin="0,0,0,18"
                Click="BtnGrades_Click"/>

        <Button Content="Выйти"
                Height="30"
                Width="120"
                HorizontalAlignment="Right"
                Click="BtnExit_Click"/>
    </StackPanel>
</Window>
