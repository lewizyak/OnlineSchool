<Window x:Class="OnlineSchool.View.AvailableCourses"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnlineSchool.View"
        mc:Ignorable="d"
        Title="AvailableCourses" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dgAvailableCourses" Grid.Row="0" IsReadOnly="True"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обновить" Width="120" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
            <Button Content="Записаться" Width="120" Margin="0,0,10,0" Click="BtnJoin_Click"/>
            <Button Content="Закрыть" Width="120" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>